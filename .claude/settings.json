{
  "model": "claude-opus-4-6",
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash",
      "WebFetch",
      "WebSearch",
      "Agent",
      "mcp__playwright__*"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".agent/hooks/pre-tool-use.sh"
          }
        ]
      }
    ]
  }
}
